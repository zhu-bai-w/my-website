---
import Badge from '../ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  tags?: string[];
  label?: string;
}

const { title, description, tags = [], label = '工具' } = Astro.props;
---

<article class="card tool-card">
  <div class="card-body">
    <span class="eyebrow">{label}</span>
    <h3>{title}</h3>
    <p>{description}</p>
    {tags.length > 0 && (
      <div class="badge-list">
        {tags.map((tag) => <Badge label={tag} />)}
      </div>
    )}
  </div>
</article>
