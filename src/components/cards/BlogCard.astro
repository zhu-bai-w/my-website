---
import Badge from '../ui/Badge.astro';
import { formatDate } from '../../lib/content';

interface Props {
  href: string;
  title: string;
  summary: string;
  date: Date;
  category: string;
  tags: string[];
  readingTime: string;
  cover?: string;
}

const { href, title, summary, date, category, tags, readingTime, cover = '/images/placeholders/blog-note.svg' } = Astro.props;
---

<a class="card blog-card" href={href}>
  <div class="cover-frame">
    <img src={cover} alt={`${title}封面`} loading="lazy" />
  </div>
  <div class="card-body">
    <div class="card-meta">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      <span>{category}</span>
      <span>{readingTime}</span>
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    <div class="badge-list" aria-label="文章标签">
      {tags.slice(0, 3).map((tag) => <Badge label={tag} />)}
    </div>
    <span class="card-action">阅读全文</span>
  </div>
</a>
