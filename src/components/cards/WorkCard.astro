---
import Badge from '../ui/Badge.astro';
import type { Locale } from '../../lib/i18n';

interface Props {
  href: string;
  title: string;
  summary: string;
  type: string;
  role: string;
  tags: string[];
  cover?: string;
  locale?: Locale;
}

const { href, title, summary, type, role, tags, cover = '/images/placeholders/game-project.svg', locale = 'zh' } = Astro.props;
---

<a class="card work-card" href={href}>
  <div class="cover-frame">
    <img src={cover} alt={locale === 'zh' ? `${title}封面` : `${title} cover`} loading="lazy" />
  </div>
  <div class="card-body">
    <div class="card-meta">
      <span>{type}</span>
      <span>{role}</span>
    </div>
    <h3>{title}</h3>
    <p>{summary}</p>
    <div class="badge-list" aria-label={locale === 'zh' ? '项目标签' : 'Project tags'}>
      {tags.slice(0, 3).map((tag) => <Badge label={tag} />)}
    </div>
    <span class="card-action">{locale === 'zh' ? '查看详情' : 'View Details'}</span>
  </div>
</a>
