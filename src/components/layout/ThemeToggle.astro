---
import { siteCopy, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'zh';
const site = siteCopy[locale];
---

<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  data-light-label={site.themeLight}
  data-dark-label={site.themeDark}
  data-light-aria={site.themeLightAria}
  data-dark-aria={site.themeDarkAria}
  aria-label={site.themeLightAria}
>
  {site.themeLight}
</button>

<script>
  const storageKey = 'bamboo-white-tea-theme';
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
  const media = window.matchMedia('(prefers-color-scheme: dark)');

  function getStoredTheme() {
    try {
      const stored = localStorage.getItem(storageKey);
      return stored === 'light' || stored === 'dark' ? stored : null;
    } catch {
      return null;
    }
  }

  function setStoredTheme(theme: 'light' | 'dark') {
    try {
      localStorage.setItem(storageKey, theme);
    } catch {
      // Theme still updates for this visit when storage is unavailable.
    }
  }

  function syncButtons(theme: 'light' | 'dark') {
    buttons.forEach((button) => {
      button.textContent = theme === 'dark' ? button.dataset.darkLabel || '' : button.dataset.lightLabel || '';
      button.setAttribute('aria-label', theme === 'dark' ? button.dataset.darkAria || '' : button.dataset.lightAria || '');
    });
  }

  function applyTheme(theme: 'light' | 'dark', persist = true) {
    document.documentElement.dataset.theme = theme;
    syncButtons(theme);
    if (persist) setStoredTheme(theme);
  }

  const initialTheme = (document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light') as 'light' | 'dark';
  syncButtons(initialTheme);

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });
  });

  media.addEventListener('change', (event) => {
    if (!getStoredTheme()) {
      applyTheme(event.matches ? 'dark' : 'light', false);
    }
  });
</script>
