---
import BambooLogo from '../ui/BambooLogo.astro';
import ThemeToggle from './ThemeToggle.astro';
import { isActivePath, localizedPath, navItems, siteCopy, type Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'zh';
const site = siteCopy[locale];
const items = navItems[locale];
const currentPath = Astro.url.pathname;
const switchLocale = locale === 'zh' ? 'en' : 'zh';
const switchHref = localizedPath(currentPath, switchLocale);
const logoTitle = locale === 'zh' ? '竹叶标志' : 'Bamboo leaf logo';
---

<header class="site-header">
  <div class="header-inner">
    <a class="site-logo" href={locale === 'zh' ? '/' : '/en/'} aria-label={site.homeLabel}>
      <BambooLogo title={logoTitle} />
      <span class="logo-text">
        <span class="logo-title">{site.name}</span>
        <span class="logo-subtitle">{site.subtitle}</span>
      </span>
    </a>

    <nav class="site-nav" data-mobile-menu aria-label={locale === 'zh' ? '主导航' : 'Main navigation'}>
      {items.map((item) => (
        <a class:list={['nav-link', isActivePath(currentPath, item.path) && 'is-active']} href={item.path}>{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="lang-switch" href={switchHref} aria-label={locale === 'zh' ? '切换到英文版' : 'Switch to Chinese version'}>
        <span>{site.langSwitch}</span>
      </a>
      <ThemeToggle locale={locale} />
      <button
        class="menu-toggle"
        type="button"
        data-menu-toggle
        data-open-label={site.menuOpen}
        data-close-label={site.menuClose}
        aria-expanded="false"
        aria-label={site.menuOpen}
      >
        <span class="menu-toggle-bars" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-mobile-menu]');

  function closeMenu() {
    menuButton?.setAttribute('aria-expanded', 'false');
    menuButton?.setAttribute('aria-label', menuButton?.dataset.openLabel || '');
    mobileMenu?.classList.remove('is-open');
  }

  menuButton?.addEventListener('click', () => {
    const nextExpanded = menuButton.getAttribute('aria-expanded') !== 'true';
    menuButton.setAttribute('aria-expanded', String(nextExpanded));
    menuButton.setAttribute(
      'aria-label',
      nextExpanded ? menuButton.dataset.closeLabel || '' : menuButton.dataset.openLabel || ''
    );
    mobileMenu?.classList.toggle('is-open', nextExpanded);
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
