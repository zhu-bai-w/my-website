---
import RoomCard from '../cards/RoomCard.astro';
import type { Locale } from '../../lib/i18n';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'zh';
const isEn = locale === 'en';
const rooms = isEn ? [
  {
    href: '/en/portfolio/',
    icon: 'P',
    title: 'Portfolio',
    description: 'Game, writing, tool, and analysis projects.'
  },
  {
    href: '/en/blog/',
    icon: 'B',
    title: 'Blog',
    description: 'Notes on game design, tool workflows, project reviews, and creative methods.'
  },
  {
    href: '/en/lab/',
    icon: 'L',
    title: 'Lab',
    description: 'Tool systems, automation, prompts, and productivity workflows.'
  },
  {
    href: '/en/resume/',
    icon: 'R',
    title: 'Resume',
    description: 'Education, project experience, skills, and career archive.'
  }
] : [
  {
    href: '/portfolio/',
    icon: '作',
    title: '作品间',
    description: '游戏、短剧、工具项目与系统分析作品。'
  },
  {
    href: '/blog/',
    icon: '书',
    title: '书房',
    description: '游戏设计、工具流程、项目复盘与创作笔记。'
  },
  {
    href: '/lab/',
    icon: '工',
    title: '工具房',
    description: '工具、自动化系统、提示词和效率工作流。'
  },
  {
    href: '/resume/',
    icon: '档',
    title: '档案柜',
    description: '教育背景、项目经历、技能栈与职业档案。'
  }
];
---

<section class="section" aria-labelledby="featured-rooms">
  <div class="container">
    <div class="section-heading">
      <div>
        <span class="section-kicker">{isEn ? 'Featured Rooms' : '精选入口'}</span>
        <h2 id="featured-rooms">{isEn ? 'Featured Rooms' : '精选房间'}</h2>
      </div>
    </div>
    <div class="room-grid">
      {rooms.map((room) => <RoomCard {...room} actionLabel={isEn ? 'Enter Room' : '进入房间'} />)}
    </div>
  </div>
</section>
