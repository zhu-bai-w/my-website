---
import type { CollectionEntry } from 'astro:content';
import BlogCard from '../cards/BlogCard.astro';
import Button from '../ui/Button.astro';
import type { Locale } from '../../lib/i18n';

interface Props {
  posts: CollectionEntry<'blog'>[];
  locale?: Locale;
}

const { posts, locale = 'zh' } = Astro.props;
const isEn = locale === 'en';
---

<section class="section section-tight" aria-labelledby="recent-notes">
  <div class="container">
    <div class="section-heading">
      <div>
        <span class="section-kicker">{isEn ? 'Recent Notes' : '最新文章'}</span>
        <h2 id="recent-notes">{isEn ? 'Recent Notes' : '最新文章'}</h2>
      </div>
      <Button href={isEn ? '/en/blog/' : '/blog/'} label={isEn ? 'Enter Blog' : '进入书房'} variant="quiet" />
    </div>
    <div class="blog-grid">
      {posts.map((post) => {
        return (
        <BlogCard
          href={`${isEn ? '/en' : ''}/blog/note/${post.slug}/`}
          title={post.data.title}
          summary={post.data.summary}
          date={post.data.date}
          category={post.data.category}
          tags={post.data.tags}
          readingTime={post.data.readingTime}
          cover={post.data.cover}
          coverDark={post.data.coverDark}
          locale={locale}
        />
        );
      })}
    </div>
  </div>
</section>
