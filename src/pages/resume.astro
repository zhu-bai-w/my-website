---
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';

const skills = ['游戏设计', '叙事设计', '工具流程', '任务表达', '项目管理', '写作'];
---

<BaseLayout title="档案柜" description="教育背景、项目经历、技能栈与职业档案。">
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">档案柜</span>
      <h1>档案柜</h1>
      <p class="lead">给招聘方快速判断经历、能力结构和项目方向的网页版本档案。</p>
      <button class="btn btn-disabled disabled-download" type="button" disabled>
        <span>下载简历文件</span>
        <small>整理中</small>
      </button>
      <p class="lead">简历文件正在整理中，当前可先查看网页版本的经历与项目档案。</p>
    </div>
  </section>

  <section class="section">
    <div class="container resume-grid">
      <article class="card info-panel">
        <h2>教育背景</h2>
        <p>围绕游戏设计、内容创作、项目管理与模型工具实践持续积累，后续可替换为正式院校与课程信息。</p>
      </article>
      <article class="card info-panel">
        <h2>项目经历</h2>
        <ul>
          <li>《属于“你”的箱庭》：叙事模拟游戏演示版，负责主策划与系统拆解。</li>
          <li>《黄金算盘》：反诈主题短剧内容项目，参与剧本与内容整理。</li>
          <li>个人信息助手系统：探索订阅源、自动化编排、模型接口与飞书的自动化链路。</li>
        </ul>
      </article>
      <article class="card info-panel">
        <h2>技能栈</h2>
        <div class="badge-list">
          {skills.map((skill) => <Badge label={skill} tone="leaf" />)}
        </div>
      </article>
      <article class="card info-panel">
        <h2>游戏经历</h2>
        <p>关注机制、系统循环、玩家体验和叙事表达，习惯把游玩观察整理为设计启发与方法论笔记。</p>
      </article>
      <article class="card info-panel">
        <h2>工具能力</h2>
        <p>使用对话助手、代码助手、模型接口、自动化编排、飞书、容器服务、工具连接协议与提示词工程搭建信息处理和创作辅助流程。</p>
      </article>
      <article class="card info-panel">
        <h2>内容创作能力</h2>
        <p>能够将主题、角色、冲突、结构和表达目标整理成可协作的文档、脚本、复盘和项目档案。</p>
      </article>
    </div>
  </section>
</BaseLayout>
