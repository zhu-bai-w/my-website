---
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';

const skills = ['Game Design', 'Narrative Design', 'AI Workflow', 'Prompt Engineering', 'Project Management', 'Writing'];
---

<BaseLayout title="档案柜 Resume" description="教育背景、项目经历、技能栈与职业档案。">
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">Resume</span>
      <h1>档案柜 Resume</h1>
      <p class="lead">给 HR 快速判断经历、能力结构和项目方向的网页版本档案。</p>
      <button class="btn btn-disabled disabled-download" type="button" disabled>
        <span>下载 PDF 简历</span>
        <small>整理中</small>
      </button>
      <p class="lead">PDF 简历正在整理中，当前可先查看网页版本的经历与项目档案。</p>
    </div>
  </section>

  <section class="section">
    <div class="container resume-grid">
      <article class="card info-panel">
        <h2>教育背景</h2>
        <p>围绕游戏设计、内容创作、项目管理与 AI 工具实践持续积累，后续可替换为正式院校与课程信息。</p>
      </article>
      <article class="card info-panel">
        <h2>项目经历</h2>
        <ul>
          <li>《属于“你”的箱庭》：叙事模拟游戏 Demo，负责主策划与系统拆解。</li>
          <li>《黄金算盘》：反诈主题短剧内容项目，参与剧本与内容整理。</li>
          <li>个人信息助手系统：探索 RSS、n8n、OpenAI 与飞书的自动化链路。</li>
        </ul>
      </article>
      <article class="card info-panel">
        <h2>技能栈</h2>
        <div class="badge-list">
          {skills.map((skill) => <Badge label={skill} tone="leaf" />)}
        </div>
      </article>
      <article class="card info-panel">
        <h2>游戏经历</h2>
        <p>关注机制、系统循环、玩家体验和叙事表达，习惯把游玩观察整理为设计启发与方法论笔记。</p>
      </article>
      <article class="card info-panel">
        <h2>AI 工具能力</h2>
        <p>使用 ChatGPT、Codex、OpenAI API、n8n、飞书、Docker、MCP 与 Prompt Engineering 搭建信息处理和创作辅助流程。</p>
      </article>
      <article class="card info-panel">
        <h2>内容创作能力</h2>
        <p>能够将主题、角色、冲突、结构和表达目标整理成可协作的文档、脚本、复盘和项目档案。</p>
      </article>
    </div>
  </section>
</BaseLayout>
