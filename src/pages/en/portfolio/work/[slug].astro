---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Badge from '../../../../components/ui/Badge.astro';
import Button from '../../../../components/ui/Button.astro';
import MarkdownContent from '../../../../components/markdown/MarkdownContent.astro';
import TableOfContents from '../../../../components/markdown/TableOfContents.astro';
import { sortWorks } from '../../../../lib/content';
import { getTemplateLabel, workCopy } from '../../../../lib/i18n';

export async function getStaticPaths() {
  const works = sortWorks(await getCollection('works'));
  return works.map((work, index) => ({
    params: { slug: work.slug },
    props: {
      work,
      previous: works[index - 1] ? { slug: works[index - 1].slug, title: workCopy(works[index - 1], 'en').title } : null,
      next: works[index + 1] ? { slug: works[index + 1].slug, title: workCopy(works[index + 1], 'en').title } : null
    }
  }));
}

const { work, previous, next } = Astro.props;
const copy = workCopy(work, 'en');
const cover = work.data.cover ?? '/images/placeholders/game-project.svg';
const templateLabel = getTemplateLabel(work.data.template, 'en');
const headings = [{ depth: 2, slug: 'overview', text: 'Overview' }];
---

<BaseLayout locale="en" title={copy.title} description={copy.summary}>
  <section class="detail-hero">
    <div class="detail-hero-inner">
      <div>
        <span class="eyebrow">{copy.type}</span>
        <h1 class="detail-title">{copy.title}</h1>
        <p class="detail-summary">{copy.summary}</p>
        <div class="badge-list" style="margin-top: 18px;">
          {copy.tags.map((tag: string) => <Badge label={tag} tone="leaf" />)}
        </div>
      </div>
      <figure class="detail-cover">
        <img src={cover} alt={`${copy.title} cover`} />
      </figure>
    </div>
  </section>

  <div class="detail-layout">
    <div class="detail-main">
      <div class="meta-panel" aria-label="Project metadata">
        <div class="meta-item">
          <span class="meta-label">Project Type</span>
          <span class="meta-value">{copy.type}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">My Role</span>
          <span class="meta-value">{copy.role}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Date</span>
          <span class="meta-value">{copy.date ?? 'Ongoing'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Status</span>
          <span class="meta-value">{copy.status}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Tools</span>
          <span class="meta-value">{copy.tools.length > 0 ? copy.tools.join(' / ') : 'Being organized'}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Template</span>
          <span class="meta-value">{templateLabel}</span>
        </div>
      </div>

      <MarkdownContent>
        <h2 id="overview">Overview</h2>
        {copy.body.map((paragraph: string) => <p>{paragraph}</p>)}
      </MarkdownContent>

      <div class="back-row">
        <Button href="/en/portfolio/" label="Back to Portfolio" variant="quiet" />
      </div>

      <nav class="pager-row" aria-label="Project navigation">
        {previous ? <Button href={`/en/portfolio/work/${previous.slug}/`} label={`Previous: ${previous.title}`} /> : <span></span>}
        {next ? <Button href={`/en/portfolio/work/${next.slug}/`} label={`Next: ${next.title}`} /> : <span></span>}
      </nav>
    </div>

    <TableOfContents headings={headings} locale="en" />
  </div>
</BaseLayout>
