---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/cards/BlogCard.astro';
import { sortPosts } from '../../../lib/content';
import { postCopy } from '../../../lib/i18n';

const posts = sortPosts(await getCollection('blog'));
const categories = ['All', 'Game Design', 'Workflow', 'Project Log', 'Writing', 'Method'];
---

<BaseLayout locale="en" title="Blog" description="Game design notes, tool workflows, project logs, writing notes, and methods.">
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">Blog</span>
      <h1>Blog</h1>
      <p class="lead">Notes on game design, tool workflows, project logs, writing, and methods.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="filter-bar" aria-label="Blog category filter">
        {categories.map((category) => (
          <button
            class:list={['filter-button', category === 'All' && 'is-active']}
            type="button"
            data-filter-button
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>

      <div class="blog-grid">
        {posts.map((post) => {
          const copy = postCopy(post, 'en');
          return (
            <div data-filter-card data-category={copy.category}>
              <BlogCard
                href={`/en/blog/note/${post.slug}/`}
                title={copy.title}
                summary={copy.summary}
                date={post.data.date}
                category={copy.category}
                tags={copy.tags}
                readingTime={copy.readingTime}
                cover={post.data.cover}
                locale="en"
              />
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-button]'));
  const filterCards = Array.from(document.querySelectorAll<HTMLElement>('[data-filter-card]'));

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const category = button.dataset.category || 'All';
      filterButtons.forEach((item) => item.classList.toggle('is-active', item === button));
      filterCards.forEach((card) => {
        card.hidden = category !== 'All' && card.dataset.category !== category;
      });
    });
  });
</script>
