---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Badge from '../../../../components/ui/Badge.astro';
import Button from '../../../../components/ui/Button.astro';
import ThemeCover from '../../../../components/ui/ThemeCover.astro';
import MarkdownContent from '../../../../components/markdown/MarkdownContent.astro';
import TableOfContents from '../../../../components/markdown/TableOfContents.astro';
import { formatDate, sortPosts } from '../../../../lib/content';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previous: posts[index - 1] ? { slug: posts[index - 1].slug, title: posts[index - 1].data.title } : null,
      next: posts[index + 1] ? { slug: posts[index + 1].slug, title: posts[index + 1].data.title } : null
    }
  }));
}

const { post, previous, next } = Astro.props;
const { Content, headings } = await render(post);
const cover = post.data.cover ?? '/images/placeholders/blog-note.svg';
const coverDark = post.data.coverDark;
---

<BaseLayout locale="en" title={post.data.title} description={post.data.summary}>
  <section class="detail-hero">
    <div class="detail-hero-inner">
      <div>
        <span class="eyebrow">{post.data.category}</span>
        <h1 class="detail-title">{post.data.title}</h1>
        <p class="detail-summary">{post.data.summary}</p>
        <div class="card-meta" style="margin-top: 18px;">
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, 'en')}</time>
          <span>{post.data.readingTime}</span>
        </div>
        <div class="badge-list" style="margin-top: 14px;">
          {post.data.tags.map((tag: string) => <Badge label={tag} tone="leaf" />)}
        </div>
      </div>
      <figure class="detail-cover">
        <ThemeCover src={cover} darkSrc={coverDark} alt={`${post.data.title} cover`} loading="eager" />
      </figure>
    </div>
  </section>

  <div class="detail-layout">
    <div class="detail-main">
      <div class="meta-panel" aria-label="Article metadata">
        <div class="meta-item">
          <span class="meta-label">Published</span>
          <span class="meta-value">{formatDate(post.data.date, 'en')}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Category</span>
          <span class="meta-value">{post.data.category}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Reading Time</span>
          <span class="meta-value">{post.data.readingTime}</span>
        </div>
      </div>

      <MarkdownContent>
        <Content />
      </MarkdownContent>

      <div class="back-row">
        <Button href="/en/blog/" label="Back to Blog" variant="quiet" />
      </div>

      <nav class="pager-row" aria-label="Article navigation">
        {previous ? <Button href={`/en/blog/note/${previous.slug}/`} label={`Previous: ${previous.title}`} /> : <span></span>}
        {next ? <Button href={`/en/blog/note/${next.slug}/`} label={`Next: ${next.title}`} /> : <span></span>}
      </nav>
    </div>

    <TableOfContents headings={headings} locale="en" />
  </div>
</BaseLayout>
